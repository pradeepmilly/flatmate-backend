# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flatmate_india
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT secret — change this to a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this

# Server
PORT=4000

# OTP (set to "true" to use real SMS, "false" to use demo OTP 1234)
USE_REAL_OTP=false

# MSG91 credentials (only needed if USE_REAL_OTP=true)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_SENDER_ID=FMTINDIA
